# =================================================================
# LifeSaver AI - Environment Configuration
# =================================================================

# Server Port
PORT=5000

# Google AI Studio API Key (for Gemini 1.5/2.5 Flash agent access)
# Get a free key at: https://aistudio.google.com/
GEMINI_API_KEY=

# Firebase Admin SDK Configuration (Optional - fallbacks to local db.json if missing)
# Obtain these from: Firebase Console -> Project Settings -> Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
